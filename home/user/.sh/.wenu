#!/usr/bin/env dash
QT_WAYLAND_DISABLE_WINDOWDECORATION=1
pkill wofi
entries="’ü╗ File\n’ćś Telegram\n’ģÆ Deadbeef\n’é¼ Browser\n’ī£ Editor\n’ć¼ Calculator\n’ć× DConf\n’Ć▒ Gucharmap\n’¢¬ Gtk-Theme\n’Ŗö Blueman\n’īé Wallpapers\n’ö▓ Terminal\n’£ż SmartTerminal\nX"

selected=$(echo $entries|wofi -x 0 --width 300 --height 490 --dmenu --cache-file /dev/null --prompt=Applications | awk '{print tolower($2)}')

case $selected in
  file)
    pcmanfm;;
  deadbeef)
    deadbeef;;
  telegram)
    kotatogram-desktop;;
  browser)
   brave;;
  editor)
    Edit;;
  calculator)
    galculator;;
  dconf)
    dconf-editor;;
  gucharmap)
    gucharmap;;
  gtk-theme)
    nwg-look;;
  blueman)
    blueman-manager;;
  wallpapers)
    waytrogen;;
  terminal)
    foot;;
  smartterminal)
    foot -a SmartTerm;;
   x)
  pkill wofi;;
esac
