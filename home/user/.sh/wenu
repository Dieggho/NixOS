#!/usr/bin/env dash

pkill fuzzel 2>/dev/null

entries="´ü╗ File
´çİ Telegram
´àÆ Deadbeef
´é¼ Browser
´î£ Editor
´ç╝ Gimp
´ç¼ Calculator
´çŞ DConf
´Ç▒ Gucharmap
´û¬ Gtk-Theme
´îé Wallpapers
´ö▓ Terminal
´£ñ SmartTerminal"

selected=$(printf '%s\n' "$entries" | fuzzel --dmenu --lines 13 --width 20 --anchor top-left --prompt "Applications > " | awk '{print tolower($2)}')

case "$selected" in
  file)
    pcmanfm
    ;;
  deadbeef)
    deadbeef
    ;;
  telegram)
    kotatogram-desktop
    ;;
  browser)
    firefox
    ;;
  editor)
    lite-xl
    ;;
  gimp)
    gimp
    ;;
  calculator)
    galculator
    ;;
  dconf)
    dconf-editor
    ;;
  gucharmap)
    gucharmap
    ;;
  gtk-theme)
    nwg-look
    ;;
  wallpapers)
    waypaper
    ;;
  terminal)
    foot
    ;;
  smartterminal)
    foot -a SmartTerm
    ;;
esac
