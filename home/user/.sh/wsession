#!/usr/bin/env dash

pkill wofi

entries="п…Ќ Logout\nвЏѕ Suspend\nп„ѕ Lock\nп‹± Reboot\nпЂ‘ Shutdown\nX"

selected=$(echo $entries|wofi -x 1710 --width 1 --height 220 --dmenu --cache-file /dev/null --prompt="Session Manager"| awk '{print tolower($2)}')

case $selected in
  logout)
    logoff;;
  suspend)
    sleep 0.3 ; systemctl suspend;;
  lock)
   sleep 0.3 ; lock;;
  reboot)
    reboot;;
  shutdown)
    poweroff;;
 x)
  pkill wofi;;
esac
