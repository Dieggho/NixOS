#!/usr/bin/env dash

pkill wofi

entries="’ŗÉ Fullscreen\n’ŗÆ Toggle-Float\n’ĆŹ Close\nx"

selected=$(echo $entries|wofi -x 49 -y 792 --width 210 --height 155 --dmenu --cache-file /dev/null | awk '{print tolower($2)}')

case $selected in
fullscreen)
    hyprctl dispatch fullscreen;;
toggle-float)
    hyprctl dispatch togglefloating;;
close)
    hyprctl dispatch killactive;;
   x)
  pkill wofi;;
esac
