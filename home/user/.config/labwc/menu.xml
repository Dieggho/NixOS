<?xml version="1.0" encoding="UTF-8"?>

<openbox_menu>
<!-- Note: for localization support of menu items "client-menu" has to be removed here -->
<menu id="client-menu">
  <item label="Minimize">
    <action name="Iconify" />
  </item>
  <item label="Maximize">
    <action name="ToggleMaximize" />
  </item>
  <item label="Fullscreen">
    <action name="ToggleFullscreen" />
  </item>
  <item label="Roll up/down">
    <action name="ToggleShade" />
  </item>
  <item label="Decorations">
    <action name="ToggleDecorations" />
  </item>
  <item label="Always on Top">
    <action name="ToggleAlwaysOnTop" />
  </item>
  <!--
    Any menu with the id "workspaces" will be hidden
    if there is only a single workspace available.
  -->
  <menu id="workspaces" label="Workspace">
   <!--
    <item label="Move left">
      <action name="SendToDesktop" to="left" />
    </item>
    <item label="Move right">
      <action name="SendToDesktop" to="right" />
    </item>
   -->   
    <item label="Move to Main">
      <action name="SendToDesktop" to="Main" follow="yes" wrap="yes" />
    </item>
     <item label="Move to Web">
      <action name="SendToDesktop" to="Web" follow="yes" wrap="yes" />
    </item>
    <item label="Move to Net">
      <action name="SendToDesktop" to="Net" follow="yes" wrap="yes" />
    </item>
     <item label="Move to Doc">
      <action name="SendToDesktop" to="Doc" follow="yes" wrap="yes" />
    </item>
    <item label="Move to Term">
      <action name="SendToDesktop" to="Term" follow="yes" wrap="yes" />
    </item>
     <item label="Move to Media">
      <action name="SendToDesktop" to="Media" follow="yes" wrap="yes" />
    </item>
     <item label="Move to Desk">
      <action name="SendToDesktop" to="Desk" follow="yes" wrap="yes" />
    </item>    
    <separator />
    <item label="Always on Visible Workspace">
      <action name="ToggleOmnipresent" />
    </item>
  </menu>
  <item label="Close">
    <action name="Close" />
  </item>
</menu>

<menu id="root-menu">
  <item label="Running Apps">
    <action name="Execute" command="appswitch" />
  </item>
  <item label="Htop">
    <action name="Execute" command="foot -a SmartTerm -e htop -u void" />
  </item>
</menu>

<menu id="some-custom-menu">
  <item label="Terminal">
    <action name="Execute" command="foot -a SmartTerm" />
  </item> 
  <item label="Wallpaper">
    <action name="Execute" command="waypaper" />
  </item>
  <item label="Reconfigure">
    <action name="Reconfigure" />
  </item>
  <!-- <item label="Exit">
    <action name="Exit" />
  </item> -->
</menu>

</openbox_menu>
