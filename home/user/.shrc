# =====================================================
ESC=$(printf '\033')

red="${ESC}[0;31m"
RED="${ESC}[1;31m"
green="${ESC}[0;32m"
GREEN="${ESC}[1;32m"
blue="${ESC}[0;34m"
BLUE="${ESC}[1;34m"
purple="${ESC}[0;35m"
PURPLE="${ESC}[1;35m"
cyan="${ESC}[0;36m"
CYAN="${ESC}[1;36m"
white="${ESC}[0;37m"
WHITE="${ESC}[1;37m"
yellow="${ESC}[0;33m"
YELLOW="${ESC}[1;33m"
NC="${ESC}[0m"

export red RED green GREEN blue BLUE purple PURPLE
export cyan CYAN white WHITE yellow YELLOW NC

# =====================================================
# ALIASES 
# =====================================================
alias myip='curl ident.me; echo'
alias mynix='clear; fastfetch; lsblk -f'
alias nixvi='doas vi /etc/nixos/configuration.nix'
alias nixhd='doas vi /etc/nixos/hardware-configuration.nix'
alias nixup='doas nixos-rebuild switch --upgrade'
alias nixrm='doas nix-collect-garbage --delete-old; doas /run/current-system/bin/switch-to-configuration boot'
alias nixs='nix-env -qaP'
alias nixsh='nix-shell -p'
alias nixr='nix-collect-garbage'
alias nixlsg='doas nix-env --list-generations --profile /nix/var/nix/profiles/system'
alias hyprrc='vi "$HOME/.config/hypr/hyprland.conf"'
alias Nix='clear; fastfetch'
alias du-='du -sh ~ /nix/store'
alias shrc='vi ~/.shrc'
alias exrc='vi ~/.exrc'
alias doas-i='doas su -'
alias clvitmp='rm -fv /tmp/vi*'
alias la='ls -la'

# =====================================================
# FUNCTIONS 
# =====================================================

# mkdir + cd
mkcd() {
    mkdir -p "$1" && cd "$1" || return 1
}

# Extrair arquivos
extract() {
    [ -f "$1" ] || return 1
    case "$1" in
        *.tar.gz|*.tgz) tar -xzf "$1" ;;
        *.tar.bz2)      tar -xjf "$1" ;;
        *.tar.xz)       tar -xJf "$1" ;;
        *.tar)          tar -xf "$1" ;;
        *.zip)          unzip "$1" ;;
        *.gz)           gunzip "$1" ;;
        *.bz2)          bunzip2 "$1" ;;
        *.xz)           unxz "$1" ;;
        *.7z)		7z x "$1" ;;
        *)              printf 'Formato não suportado\n' ;;
    esac
}

# =====================================================
# PROMPT 
# =====================================================
PS1=$'${BLUE}>${NC} '
export PS1

# =====================================================
# mksh bindings
# =====================================================
if [ -n "$KSH_VERSION" ]; then
     bind ^[a=beginning-of-line
     bind ^[e=end-of-line
     bind ^L=clear-screen
fi
